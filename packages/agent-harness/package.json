{
  "name": "@zarb/agent-harness",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./runtime": {
      "import": "./dist/runtime/index.js",
      "types": "./dist/runtime/index.d.ts"
    },
    "./exploration": {
      "import": "./dist/exploration/index.js",
      "types": "./dist/exploration/index.d.ts"
    },
    "./code-repair": {
