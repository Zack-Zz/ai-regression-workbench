{
  "name": "ai-regression-workbench",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local-first AI regression testing and controlled remediation workbench",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "scripts": {
    "dev:api": "pnpm -s tsc -b apps/cli && node apps/cli/dist/bin.js",
    "dev:api:debug": "pnpm -s tsc -b apps/cli && node --inspect=9229 apps/cli/dist/bin.js",
    "dev:api:watch": "node scripts/dev-api.mjs",
    "dev:api:watch:debug": "node scripts/dev-api.mjs --inspect=9229",
    "dev:ui": "pnpm --filter @zarb/local-ui dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.58.2",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0"
  }
}
